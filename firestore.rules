rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function groupOwner(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }

    function groupMember(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /members/{memberId} {
        // Collection-group membership reads are needed to assemble accessible groups.
        allow read: if signedIn();
        allow create: if signedIn() && (
          groupOwner(groupId)
          || request.resource.data.userId == request.auth.uid
        );
        allow update: if signedIn() && (
          groupOwner(groupId)
          || request.auth.uid == memberId
          || resource.data.userId == request.auth.uid
        );
        allow delete: if signedIn() && (
          groupOwner(groupId)
          || request.auth.uid == memberId
          || resource.data.userId == request.auth.uid
        );
      }

      match /expenses/{expenseId} {
        allow read: if signedIn() && (groupOwner(groupId) || groupMember(groupId));
        allow create, update, delete: if signedIn() && groupOwner(groupId);

        match /participants/{participantId} {
          allow read: if signedIn() && (groupOwner(groupId) || groupMember(groupId));
          allow create, update, delete: if signedIn() && groupOwner(groupId);
        }
      }
    }
  }
}
